generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////
// ENUMS
//////////////////////////

model Patient {
  id       String  @id @default(uuid())
  fullName String
  email    String  @unique
  phone    String?

  appointments Appointment[]
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

model Doctor {
  id              String  @id @default(uuid())
  fullName        String
  email           String  @unique
  phone           String?
  password        String
  specialization  String
  bio             String?
  experience      Int?
  consultationFee Float?
  image           String?

  // إضافات مفيدة
  isAvailable Boolean @default(true)
  rating      Float? // تقييم الطبيب
  location    String? // العنوان

  appointments Appointment[]
  schedules    Schedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Schedule {
  id        String @id @default(uuid())
  dayOfWeek Int // 0 = الأحد ... 6 = السبت
  startTime String // "09:00"
  endTime   String // "17:00"

  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id])
}

model Appointment {
  id     String   @id @default(uuid())
  date   DateTime
  status String // pending, confirmed, cancelled

  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id])

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  createdAt DateTime @default(now())
}

enum Status {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

