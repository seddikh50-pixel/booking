generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}
datasource db {
  provider = "postgresql"
}
//////////////////////////
// ENUMS
//////////////////////////

model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  password     String
  role         Role       @default(PATIENT)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // العلاقات
  doctorProfile Doctor?      // إذا كان هذا المستخدم طبيب
  appointments  Appointment[] // المواعيد التي حجزها المريض
  reviews       Review[]      // تقييمات المريض
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

model Doctor {
  id           Int        @id @default(autoincrement())
  user         User       @relation(fields: [userId], references: [id])
  userId       Int        @unique
  specialty    String
  bio          String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // العلاقات
  appointments Appointment[]
  reviews      Review[]
}

model Appointment {
  id          Int       @id @default(autoincrement())
  doctor      Doctor    @relation(fields: [doctorId], references: [id])
  doctorId    Int
  patient     User      @relation(fields: [patientId], references: [id])
  patientId   Int
  date        DateTime
  status      Status    @default(PENDING)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum Status {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Review {
  id          Int       @id @default(autoincrement())
  doctor      Doctor    @relation(fields: [doctorId], references: [id])
  doctorId    Int
  patient     User      @relation(fields: [patientId], references: [id])
  patientId   Int
  rating      Int       // 1-5
  comment     String?
  createdAt   DateTime  @default(now())
}